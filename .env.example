# Kninix Studio — headless MCP server config. Copy to `.env` and adjust.
# All are optional; sensible defaults are shown.

# --- Transport -------------------------------------------------------------
# stdio (default, unset) or http. HTTP is for remote MCP clients over the network.
KX_MCP_TRANSPORT=http

# Force headless (own in-process Engine, no GUI). Implied by --http / KX_MCP_TRANSPORT=http.
KX_HEADLESS=1

# HTTP bind. Use 127.0.0.1 and reach it via SSH tunnel (safest), OR 0.0.0.0 + a token.
KX_MCP_HOST=127.0.0.1
KX_MCP_PORT=3333

# REQUIRED whenever KX_MCP_HOST is not loopback. Long random string; clients send it as
# `Authorization: Bearer <token>` or `?token=<token>`. Generate: openssl rand -hex 32
# KX_MCP_TOKEN=replace-with-a-long-random-secret

# --- Storage ---------------------------------------------------------------
# Where imports, proxies, thumbnails, samples and exports live (defaults to OS tmp).
# KX_DATA_DIR=/var/lib/kninix
# KX_OUT_DIR=/var/lib/kninix/exports

# --- Media / ffmpeg --------------------------------------------------------
# Override binary locations if ffmpeg/ffprobe are not on PATH.
# KX_FFMPEG=/usr/bin/ffmpeg
# KX_FFPROBE=/usr/bin/ffprobe

# Encoder: auto (default, probes for GPU) | libx264 | h264_nvenc | h264_qsv | h264_amf.
# On a typical CPU-only VPS, pin libx264 to skip GPU probing.
# KX_ENCODER=libx264

# Concurrent ffmpeg jobs (default 4). Match to available CPU cores on the VPS.
# KX_MAX_CONCURRENT=4
